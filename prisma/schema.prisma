generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String?
  image          String?
  password       String?
  credits        Int          @default(0)
  plan           String       @default("free") // free | pro | business
  planExpiresAt  DateTime?
  createdAt      DateTime     @default(now())
  invitations    Invitation[]
}

model Invitation {
  id          String   @id @default(cuid())
  userId      String
  slug        String   @unique
  category    String   // wedding | business | medical | birthday
  themeId     String
  status      String   @default("draft") // draft | published | archived
  content     String   // JSON
  options     String   // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt       DateTime?
  clientAccessToken String?   @unique
  clientEmail       String?
  clientName        String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests            Guest[]
  views             InvitationView[]
}

model Theme {
  id           String  @id @default(cuid())
  category     String
  name         String
  slug         String  @unique
  previewImage String?
  isPremium    Boolean @default(false)
  config       String  // JSON — design tokens + shape + opening + layout
}

model Guest {
  id           String     @id @default(cuid())
  invitationId String
  name         String
  contact      String?
  status       String     @default("pending") // pending | attending | declined | checked_in
  partySize    Int        @default(1)
  message      String?
  respondedAt  DateTime?
  checkedInAt  DateTime?
  token        String     @unique @default(cuid())
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
}

model InvitationView {
  id           String     @id @default(cuid())
  invitationId String
  viewedAt     DateTime   @default(now())
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
}

model ProcessedWebhook {
  checkoutId  String   @id
  processedAt DateTime @default(now())
}

model PendingCheckout {
  checkoutId String   @id
  userId     String
  type       String   // subscription | credits
  plan       String?
  months     Int      @default(1)
  credits    Int      @default(0)
  createdAt  DateTime @default(now())
}

model GeneratedTheme {
  id             String   @id @default(cuid())
  baseThemeId    String
  customizations String   // JSON Record<string, string>
  layoutSpec     String?  // JSON DynamicThemeSpec — null for old entries
  category       String
  label          String   // ex: "Mariage Bordeaux & Lune"
  isPublic       Boolean  @default(true)
  isPromoted     Boolean  @default(false)
  createdAt      DateTime @default(now())
}
